# 必填：LLM 密钥
ANTHROPIC_API_KEY=sk-ant-xxxx

# 以下全部可选（默认值见 pipeline/config.py）
# ANTHROPIC_BASE_URL=                 # 走代理/网关时填
# STORYBOARD_MODEL=claude-sonnet-5    # 转换用模型（prompt 按强模型理解力编写，不建议低于此档）
# STORYBOARD_MAX_TOKENS=32000         # 单批输出上限，被截断时调大
# STORYBOARD_TEMPERATURE=0.2
# STORYBOARD_BATCH_CHARS=2500         # 分批目标字符数
# STORYBOARD_SINGLE_BATCH_MAX=3200    # 不超过此长度不分批
# STORYBOARD_MAX_RETRIES=2            # 校验失败回喂重试次数
# STORYBOARD_SERVER_WORKERS=1         # HTTP 服务并发转换任务数
