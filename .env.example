# 必填：LLM 密钥
ANTHROPIC_API_KEY=sk-ant-xxxx

# 以下全部可选（默认值见 pipeline/config.py）
# ANTHROPIC_BASE_URL=                 # 走代理/网关时填
# STORYBOARD_MODEL=claude-sonnet-5    # 转换用模型（prompt 按强模型理解力编写，不建议低于此档）
# STORYBOARD_MAX_TOKENS=32000         # 单批输出上限，被截断时调大
# STORYBOARD_TEMPERATURE=0.2
# STORYBOARD_BATCH_CHARS=2500         # 分批目标字符数
# STORYBOARD_SINGLE_BATCH_MAX=3200    # 不超过此长度不分批
# STORYBOARD_MAX_RETRIES=2            # 校验/质量门失败回喂重试次数
# STORYBOARD_TRANSPORT_RETRIES=3      # LLM 瞬时传输故障（断连/超时/5xx/限流）指数退避重试次数
# STORYBOARD_NORMALIZE_INPUT=1        # 入口剔除零宽/BOM 噪声字符（置 0 关闭；关闭后弱模型
#                                     #   很难在 JSON 里逐字复制不可见字符，易保真失败）
# STORYBOARD_SERVER_WORKERS=1         # HTTP 服务并发转换任务数

# 质量层（弱模型部署时的兜底）
# STORYBOARD_NARRATION_DENSITY_MAX=0.6  # selective 模式旁白占比质量门（>=1 关闭）
# STORYBOARD_STRICT=1                   # 软质量门重试耗尽时直接失败（默认择优降级交付并附质量报告；
#                                       #   硬校验 schema/lint/保真失败不受此开关影响，始终直接失败）
# STORYBOARD_REVIEW=1                   # 开启 LLM 评审阶段（默认关）
# STORYBOARD_REVIEW_MODEL=              # 评审用模型，缺省与转换同模型（建议用更强档）
# STORYBOARD_REVIEW_MIN_SCORE=3.0       # 评审总分阈值，低于则回喂 issues 重试
