  "source": {
    "work_title": "橘子汽水",
    "chapter": "第七章 天台",
    "units": [
      {
        "id": "u0001",
        "text": "许辞把两瓶橘子汽水放在天台的矮墙上，其中一瓶推到了乔一面前。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0002",
        "text": "“喝吧，赔罪的。”他说。",
        "para": 1,
        "kind": "dialogue"
      },
      {
        "id": "u0003",
        "text": "乔一没有伸手，风把她的校服裙摆吹起一个小小的弧度。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0004",
        "text": "“你昨天为什么不来？”她盯着汽水瓶上凝结的水珠。",
        "para": 1,
        "kind": "dialogue"
      },
      {
        "id": "u0005",
        "text": "许辞沉默了几秒，指尖在瓶盖上摩挲。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0006",
        "text": "“我妈住院了。”他的声音很轻，像是怕惊动什么。",
        "para": 1,
        "kind": "dialogue"
      },
      {
        "id": "u0007",
        "text": "乔一猛地抬头。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0008",
        "text": "她想起昨天在礼堂门口，自己是怎么当着全班的面把节目单摔在地上的。",
        "para": 1,
        "kind": "psychology"
      },
      {
        "id": "u0009",
        "text": "胃里泛起一阵酸涩的悔意。",
        "para": 1,
        "kind": "psychology"
      },
      {
        "id": "u0010",
        "text": "“对不起。”两个人几乎同时开口。",
        "para": 1,
        "kind": "dialogue"
      },
      {
        "id": "u0011",
        "text": "汽水瓶在夕阳里透出橙色的光，像那年夏天所有没说出口的话。",
        "para": 1,
        "kind": "description"
      }
    ]
  },
