  "source": {
    "work_title": "山河故人帖",
    "chapter": "卷二 夜宴",
    "units": [
      {
        "id": "u0001",
        "text": "是夜，雪满长安。",
        "para": 1,
        "kind": "description"
      },
      {
        "id": "u0002",
        "text": "沈太傅设宴于听雪楼，满座朱紫，觥筹交错。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0003",
        "text": "李昭衣白衣按剑，立于阶下，不饮不语。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0004",
        "text": "太傅举杯遥指之，笑曰：“李郎年少成名，何故郁郁？”",
        "para": 1,
        "kind": "dialogue"
      },
      {
        "id": "u0005",
        "text": "座中皆笑。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0006",
        "text": "李昭衣不答，只将腰间旧剑解下，横置于案。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0007",
        "text": "剑鞘斑驳，隐见血痕。",
        "para": 1,
        "kind": "description"
      },
      {
        "id": "u0008",
        "text": "满堂笑声渐熄。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0009",
        "text": "太傅面色微变，杯中酒晃出涟漪。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0010",
        "text": "昔年北关一役，三千骑尽没于风雪，唯此剑归。",
        "para": 1,
        "kind": "narration_meta"
      },
      {
        "id": "u0011",
        "text": "李昭衣执剑起身，一字一句道：“此剑之主，临终托我问太傅一句话。”",
        "para": 1,
        "kind": "dialogue"
      },
      {
        "id": "u0012",
        "text": "烛火摇曳，映得他眉目如霜。",
        "para": 1,
        "kind": "description"
      },
      {
        "id": "u0013",
        "text": "“粮草，为何迟了七日？”",
        "para": 1,
        "kind": "dialogue"
      }
    ]
  },
