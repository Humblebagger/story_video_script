  "source": {
    "work_title": "深夜来电",
    "chapter": "第一章 十一点十七分",
    "units": [
      {
        "id": "u0001",
        "text": "雨下到第三个小时，城市像被泡在墨水里。",
        "para": 1,
        "kind": "description"
      },
      {
        "id": "u0002",
        "text": "林晚坐在出租屋的窗边，手机屏幕亮了。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0003",
        "text": "是一个陌生号码，归属地显示：本市。",
        "para": 1,
        "kind": "description"
      },
      {
        "id": "u0004",
        "text": "她犹豫了三秒，还是接了。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0005",
        "text": "“林小姐，你姐姐出事前，最后见的人是我。”",
        "para": 1,
        "kind": "dialogue"
      },
      {
        "id": "u0006",
        "text": "电话那头是个男人，声音平静得不像在谈论一桩死亡。",
        "para": 1,
        "kind": "description"
      },
      {
        "id": "u0007",
        "text": "林晚的呼吸停了半拍，三年了，从没有人主动提起姐姐。",
        "para": 1,
        "kind": "psychology"
      },
      {
        "id": "u0008",
        "text": "“你是谁？”",
        "para": 1,
        "kind": "dialogue"
      },
      {
        "id": "u0009",
        "text": "她听见自己的声音在发抖。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0010",
        "text": "“明天上午十点，老码头咖啡馆。带上你姐姐留给你的那把钥匙。”",
        "para": 1,
        "kind": "dialogue"
      },
      {
        "id": "u0011",
        "text": "电话挂断了。",
        "para": 1,
        "kind": "action"
      },
      {
        "id": "u0012",
        "text": "窗外一道闪电劈开夜空，她才发现自己的指甲已经掐进了掌心。",
        "para": 1,
        "kind": "action"
      }
    ]
  },
